# Ignore everything, then whitelist only what the VSIX needs.
# This prevents stray files (docs, scripts, configs) from leaking
# into the published extension package.
*
*/**

# Webpack output (extension.js + askpass helper)
!dist/
!dist/**

# Extension manifest and metadata
!package.json
!README.md
!LICENSE
!CHANGELOG.md

# Exclude source maps from dist/ (nosources-source-map)
dist/**/*.map
